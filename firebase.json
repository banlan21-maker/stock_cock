{
    "functions": [
        {
            "source": "backend",
            "codebase": "default",
            "ignore": [
                "venv",
                ".venv",
                "__pycache__",
                "*.pyc",
                ".env",
                "*.env",
                "docs_cache",
                "db",
                "scripts",
                "supabase_schema",
                "check_imports.py",
                "create_user.py"
            ],
            "runtime": "python312"
        }
    ],
    "hosting": {
        "source": "frontend",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "frameworksBackend": {
            "region": "us-central1",
            "timeoutSeconds": 60,
            "minInstances": 0
        },
        "rewrites": [
            {
                "source": "/api/**",
                "function": "api"
            }
        ]
    }
}